@layouts.master({title: post.title})

    <h1 class="ui header">{{ post.title }}</h1>
    <p>{{ post.body }}</p>
    <hr>
    <h3 class="ui header">Comments ( {{ post.comments.length }} )</h3>
    @each(comment in post.comments)
        <p><b>{{ comment.poster }} @ {{ comment.postedOn }}</b></p>
        <p>{{ comment.comment }}</p>
        <hr>
    @end
    @include('comments/commentform')
@end